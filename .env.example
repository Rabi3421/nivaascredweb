# ─────────────────────────────────────────────────────────────────
# NivaasCred — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:4028
NEXT_PUBLIC_API_URL=http://localhost:4028/api

# ── MongoDB ────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=

# ── JWT ────────────────────────────────────────────────────────────
# Generate secrets with: openssl rand -base64 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Superadmin Seed ────────────────────────────────────────────────
SUPERADMIN_FULL_NAME=
SUPERADMIN_EMAIL=
SUPERADMIN_PHONE=
SUPERADMIN_PASSWORD=

# ── AWS S3 (Phase 7 — file uploads) ───────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_IMAGES_BUCKET=nivaascred-images
AWS_S3_DOCUMENTS_BUCKET=nivaascred-docs

# ── Email — Resend (Phase 9 — notifications) ──────────────────────
RESEND_API_KEY=
EMAIL_FROM=no-reply@nivaascred.com

# ── SMS — MSG91 (Phase 9 — OTP / critical alerts) ─────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID_OTP=

# ── Payments — Razorpay (Phase 5) ─────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Redis — Upstash (rate limiting / caching) ─────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
